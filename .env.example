# ─── JWT ────────────────────────────────────────────────────────────────────
# Required: at least 32 characters for HMAC-SHA256 signing
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Optional: override issuer / audience / token lifetime
JWT_ISSUER=dotnet-template
JWT_AUDIENCE=dotnet-template
JWT_EXPIRATION_SECONDS=3600
